{
  "name": "@markylaredo/vue-autofit-text",
  "version": "1.0.3",
  "description": "Lightweight Vue auto-fit text directive for Vue 2, Vue 3, Nuxt 2, and Nuxt 3 with TypeScript support",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./nuxt2": {
      "types": "./src/nuxt2.d.ts",
      "import": "./src/nuxt2.js",
      "default": "./src/nuxt2.js"
    },
    "./nuxt3": {
      "types": "./src/nuxt3.d.ts",
      "import": "./src/nuxt3.js",
      "default": "./src/nuxt3.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "vue": ">=2.6.0 <4"
  },
  "scripts": {
    "test": "node --test test/**/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue2",
    "vue3",
    "nuxt",
    "nuxt2",
    "nuxt3",
    "directive",
    "autofit",
    "auto-fit",
    "text-fit",
    "responsive-text",
    "typography",
    "typescript",
    "plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markylaredo/vue-autofit-text.git"
  },
  "homepage": "https://github.com/markylaredo/vue-autofit-text#readme",
  "bugs": {
    "url": "https://github.com/markylaredo/vue-autofit-text/issues"
  },
  "license": "MIT"
}
